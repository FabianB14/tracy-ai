# Secrets — never commit real keys.
# Ignore .env and every .env.* variant, but keep the committed template.
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Logs (conversation logs may contain user data — keep out of git)
logs/
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store

# Capacitor native projects (generated locally via `npx cap add`) + build output
/android/
/ios/
.gradle/
*.apk
*.aab
