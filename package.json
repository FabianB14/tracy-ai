{
  "name": "tracy-assistant",
  "version": "0.1.0",
  "description": "Tracy — the Interverse AI assistant (one brain, many surfaces)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "native:bundle": "esbuild web/native/bridge.js --bundle --format=iife --outfile=web/native.bundle.js --minify",
    "native:sync": "npm run native:bundle && npx cap sync"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor-community/text-to-speech": "^8.0.2",
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "esbuild": "^0.28.1"
  }
}
