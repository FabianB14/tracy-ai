# Get a key at https://console.anthropic.com (pay-as-you-go, no credit check)
ANTHROPIC_API_KEY=sk-ant-...

# Model Tracy runs on. Swap to claude-haiku-4-5 for cheaper high-volume tasks.
TRACY_MODEL=claude-sonnet-4-6

PORT=3000

# --- Web search (Tracy can look up current info) ---
# On by default. Set to "off" to disable. Uses Anthropic's server-side web search
# (billed ~$10 per 1000 searches on your Anthropic account). Needs a recent model
# (Sonnet 4.6+ / Opus 4.6+), which TRACY_MODEL already is.
# TRACY_WEB_SEARCH=on
# Max searches Tracy may run per reply (cost cap). Default 5.
# TRACY_WEB_SEARCH_MAX_USES=5

# Conversation logging + per-user memory storage. Unset = local file fallback.
# On Render, set this to your Postgres INTERNAL Database URL.
# DATABASE_URL=postgresql://user:pass@host/db

# --- Access-key auth (optional) ---
# Set AUTH_SECRET to REQUIRE an access key to use /chat. Leave it unset to keep
# the site open. Use a long random string (e.g. `openssl rand -hex 32`).
# AUTH_SECRET=change-me-to-a-long-random-string
#
# Access keys people enter. Comma-separated. You can also generate managed,
# revocable keys into Postgres with: node scripts/genkey.js "label"
# ACCESS_KEYS=tracy-aaaa-bbbb-cccc,tracy-dddd-eeee-ffff

# Restrict which frontend origins may call the API (comma-separated). Unset = any.
# CORS_ORIGINS=https://tracy-ai.onrender.com

# --- Admin surface (business stats) ---
# Only these Tracy userIds may use the admin tools (get_babyresell_stats, etc.).
# Find your userId in the app's Settings → User ID. Unset = admin tools refuse.
# ADMIN_USER_IDS=web-xxxxxxxx

# --- BabyResell connection (for the admin "how's it doing" tools) ---
# Deployed BabyResell backend base URL.
# BABYRESELL_API_URL=https://babyresell-backend.onrender.com
# Auth — pick ONE:
#  A) Service key (recommended): a read-only pass BabyResell recognizes. Set the
#     SAME value as TRACY_SERVICE_KEY on the BabyResell backend. No Mongo _id, no
#     shared JWT secret, no expiry.
# BABYRESELL_SERVICE_KEY=tracy-svc-...
#  B) Self-minted admin JWT: BABYRESELL_JWT_SECRET must equal BabyResell's
#     JWT_SECRET; the user id is an admin user's Mongo _id.
# BABYRESELL_JWT_SECRET=same-as-babyresell-backend-JWT_SECRET
# BABYRESELL_ADMIN_USER_ID=<admin user's Mongo _id>
#  C) Simple passthrough: an admin Bearer token (expires; refresh when it does).
# BABYRESELL_ADMIN_TOKEN=<admin JWT or Firebase token>
